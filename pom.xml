<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>app.univtool</groupId>
  <artifactId>univtool</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <properties>
    <!-- Java -->
    <maven.compiler.release>17</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <!-- App meta -->
    <app.name>UnivTool</app.name>
    <vendor.name>UnivTool Project</vendor.name>
    <main.class>app.univtool.MainApp</main.class>

    <!-- JavaFX -->
    <javafx.version>21.0.5</javafx.version>

    <!-- jpackage I/O -->
    <jpackage.input>${project.build.directory}/jpackage</jpackage.input>
    <jpackage.output>${project.build.directory}/dist</jpackage.output>

    <!-- 指定のパス -->
    <installer.icon>${project.basedir}/src/main/deploy/windows/univtool.ico</installer.icon>
    <license.file>${project.basedir}/src/main/deploy/windows/LICENSES.txt</license.file>

    <!-- 固定GUID（アップグレードID） -->
    <win.upgrade.uuid>9a1ee3ab-8a2d-4b86-8a83-5cf3a4a64b3a</win.upgrade.uuid>
  </properties>

  <dependencies>
    <!-- JavaFX (Windows 向け) -->
    <dependency>
      <groupId>org.openjfx</groupId><artifactId>javafx-base</artifactId>
      <version>${javafx.version}</version><classifier>win</classifier>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId><artifactId>javafx-graphics</artifactId>
      <version>${javafx.version}</version><classifier>win</classifier>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId><artifactId>javafx-controls</artifactId>
      <version>${javafx.version}</version><classifier>win</classifier>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId><artifactId>javafx-fxml</artifactId>
      <version>${javafx.version}</version><classifier>win</classifier>
    </dependency>

    <!-- SQLite JDBC -->
    <dependency>
      <groupId>org.xerial</groupId><artifactId>sqlite-jdbc</artifactId>
      <version>3.46.0.0</version>
    </dependency>

    <!-- Gson -->
    <dependency>
      <groupId>com.google.code.gson</groupId><artifactId>gson</artifactId>
      <version>2.11.0</version>
    </dependency>

    <!-- Apache POI -->
    <dependency>
      <groupId>org.apache.poi</groupId><artifactId>poi-ooxml</artifactId>
      <version>5.2.5</version>
    </dependency>

    <!-- Log4j2 -->
    <dependency>
      <groupId>org.apache.logging.log4j</groupId><artifactId>log4j-api</artifactId>
      <version>2.21.1</version>
    </dependency>
    <dependency>
      <groupId>org.apache.logging.log4j</groupId><artifactId>log4j-core</artifactId>
      <version>2.21.1</version>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <!-- Eclipse 実行用 -->
      <plugin>
        <groupId>org.openjfx</groupId>
        <artifactId>javafx-maven-plugin</artifactId>
        <version>0.0.8</version>
        <configuration>
          <mainClass>${main.class}</mainClass>
        </configuration>
      </plugin>

      <!-- 実行Jar: Manifest に Main-Class と Class-Path を書く（lib/ 前提） -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.3.0</version>
        <configuration>
          <archive>
            <manifest>
              <mainClass>${main.class}</mainClass>
              <addClasspath>true</addClasspath>
              <classpathPrefix>lib/</classpathPrefix>
            </manifest>
          </archive>
        </configuration>
      </plugin>

      <!-- 依存Jar を jpackage 入力用 lib/ にコピー -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-dependency-plugin</artifactId>
        <version>3.6.1</version>
        <executions>
          <execution>
            <id>copy-deps-for-jpackage</id>
            <phase>package</phase>
            <goals><goal>copy-dependencies</goal></goals>
            <configuration>
              <includeScope>runtime</includeScope>
              <outputDirectory>${jpackage.input}/lib</outputDirectory>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- 本体 Jar を jpackage 入力直下へ -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.3.1</version>
        <executions>
          <execution>
            <id>copy-main-jar-for-jpackage</id>
            <phase>package</phase>
            <goals><goal>copy-resources</goal></goals>
            <configuration>
              <outputDirectory>${jpackage.input}</outputDirectory>
              <resources>
                <resource>
                  <directory>${project.build.directory}</directory>
                  <includes>
                    <include>${project.build.finalName}.jar</include>
                  </includes>
                </resource>
              </resources>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- jpackage 実行（EXE / 本番設定） -->
      <plugin>
        <groupId>org.panteleyev</groupId>
        <artifactId>jpackage-maven-plugin</artifactId>
        <version>1.7.1</version>
        <executions>
          <execution>
            <id>make-exe</id>
            <phase>package</phase>
            <goals><goal>jpackage</goal></goals>
            <configuration>
              <name>${app.name}</name>
              <appVersion>${project.version}</appVersion>
              <vendor>${vendor.name}</vendor>
              <input>${jpackage.input}</input>
              <destination>${jpackage.output}</destination>
              <removeDestination>true</removeDestination>
              <type>EXE</type>

              <mainJar>${project.build.finalName}.jar</mainJar>
              <mainClass>${main.class}</mainClass>

              <!-- まるごとJDKを同梱 -->
              <runtimeImage>${java.home}</runtimeImage>

              <icon>${installer.icon}</icon>
              <licenseFile>${license.file}</licenseFile>

              <!-- Windows -->
              <winMenu>true</winMenu>
              <winShortcut>true</winShortcut>
              <winPerUserInstall>true</winPerUserInstall>
              <winDirChooser>true</winDirChooser>
              <winMenuGroup>UnivTool</winMenuGroup>
              <winUpgradeUuid>${win.upgrade.uuid}</winUpgradeUuid>

              <!-- 本番：JavaFX をモジュールとして読み込む設定のみ残す -->
              <javaOptions>
                <javaOption>--module-path</javaOption>
                <javaOption>$APPDIR\lib</javaOption>
                <javaOption>--add-modules</javaOption>
                <javaOption>javafx.base,javafx.graphics,javafx.controls,javafx.fxml</javaOption>
                <javaOption>-Dfile.encoding=UTF-8</javaOption>
              </javaOptions>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <!-- MSI 生成用（必要時: -P msi） -->
    <profile>
      <id>msi</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.panteleyev</groupId>
            <artifactId>jpackage-maven-plugin</artifactId>
            <version>1.7.1</version>
            <executions>
              <execution>
                <id>make-msi</id>
                <phase>package</phase>
                <goals><goal>jpackage</goal></goals>
                <configuration>
                  <name>${app.name}</name>
                  <appVersion>${project.version}</appVersion>
                  <vendor>${vendor.name}</vendor>
                  <input>${jpackage.input}</input>
                  <destination>${jpackage.output}</destination>
                  <removeDestination>false</removeDestination>
                  <type>MSI</type>

                  <mainJar>${project.build.finalName}.jar</mainJar>
                  <mainClass>${main.class}</mainClass>
                  <runtimeImage>${java.home}</runtimeImage>

                  <icon>${installer.icon}</icon>
                  <licenseFile>${license.file}</licenseFile>

                  <winMenu>true</winMenu>
                  <winShortcut>true</winShortcut>
                  <winPerUserInstall>true</winPerUserInstall>
                  <winDirChooser>true</winDirChooser>
                  <winMenuGroup>UnivTool</winMenuGroup>
                  <winUpgradeUuid>${win.upgrade.uuid}</winUpgradeUuid>

                  <javaOptions>
                    <javaOption>--module-path</javaOption>
                    <javaOption>$APPDIR\lib</javaOption>
                    <javaOption>--add-modules</javaOption>
                    <javaOption>javafx.base,javafx.graphics,javafx.controls,javafx.fxml</javaOption>
                    <javaOption>-Dfile.encoding=UTF-8</javaOption>
                  </javaOptions>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
